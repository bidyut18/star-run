{
  "name": "star-run",
  "version": "0.0.3",
  "description": "Universal package manager script runner for JS/TS projects — fast, zero config, distributed via npm",
  "main": "index.js",
  "bin": {
    "star-run": "index.js"
  },
  "files": [
    "index.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "go build -ldflags=\"-s -w\" -o bin/star-run ./src",
    "build:all": "make build-all",
    "package:npm": "make package-npm",
    "test": "go test -v ./...",
    "lint": "golangci-lint run",
    "clean": "rm -rf bin/ npm/ dist/",
    "precommit": "npm run lint && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bidyut18/star-run.git"
  },
  "bugs": {
    "url": "https://github.com/bidyut18/star-run/issues"
  },
  "homepage": "https://github.com/bidyut18/star-run#readme",
  "keywords": [
    "runner",
    "package-manager",
    "npm",
    "yarn",
    "pnpm",
    "bun",
    "go",
    "cli"
  ],
  "license": "MIT",
  "author": "Bidyut Mahanta <bidyutmahanta7768@outlook.com>",
  "engines": {
    "node": ">=21.0.0",
    "npm": ">=7.0.0"
  }
}